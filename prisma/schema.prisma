// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String?  @unique
  emailVerified DateTime?
  image         String?

  accounts      Account[]
  sessions      Session[]

  // DISCORD
  discordId     String?  @unique
  username      String?

  createdAt     DateTime @default(now())

  // ROLE SYSTEM
  role          Role     @default(USER)

  // APPROVAL SYSTEM
  status        String   @default("pending") // pending | approved | rejected | banned
  isApproved    Boolean  @default(false)

  // STREAMY
  twitchUrl     String?
  youtubeUrl    String?
  kickUrl       String?

  // STEAM
  steamId       String?   @unique
  steamProfile  String?

  // STATUSY
  isOnline      Boolean  @default(false)
  isLive        Boolean  @default(false)
  livePlatform  String?

  // GRY (many-to-many)
  games         Game[]   @relation("UserGames")

  // SESJE CZASU W GRACH
  gameSessions  GameSession[]
  lastSeen      DateTime?
 activityStart DateTime?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// 🔥 GRA – wiele userów, obrazek, timery
model Game {
  id        String         @id @default(cuid())
  name      String
  image     String?        // URL tła / bannera
  players   User[]         @relation("UserGames")
  sessions  GameSession[]  // sesje czasu gry
}

// 🔥 SESJA CZASU W GRZE (do liczników)
model GameSession {
  id        String   @id @default(cuid())
  userId    String
  gameId    String

  startedAt DateTime @default(now())
  endedAt   DateTime?

  // Możesz też trzymać zliczony czas w sekundach/minutach
  totalSeconds Int?   // opcjonalnie, jeśli chcesz preliczyć

  user User @relation(fields: [userId], references: [id])
  game Game @relation(fields: [gameId], references: [id])

  @@index([userId])
  @@index([gameId])
}
